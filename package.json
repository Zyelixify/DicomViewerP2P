{
  "name": "peer-to-peer-dicom-viewer",
  "version": "0.1.0",
  "description": "Zero-config serverless P2P DICOM viewer prototype",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist:win": "electron-vite build && electron-builder --win nsis",
    "dist:portable": "electron-vite build && electron-builder --win portable"
  },
  "dependencies": {
    "@cornerstonejs/core": "^4.17.2",
    "@cornerstonejs/dicom-image-loader": "^4.17.2",
    "dicom-parser": "^1.8.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@types/node": "^22.19.11",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.zyelixify.dicomviewerp2p",
    "productName": "DicomViewerP2P",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
